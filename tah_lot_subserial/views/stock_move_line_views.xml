<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_stock_move_line_operation_tree_subserial" model="ir.ui.view">
        <field name="name">stock.move.line.operations.tree.subserial</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="lot_subserial_id"
                       groups="stock.group_production_lot"
                       invisible="not context.get('show_lots_m2o')"
                       readonly="package_level_id and parent.picking_type_entire_packs"
                       context="{'default_lot_id': lot_id, 'default_product_id': product_id, 'default_company_id': company_id}"
                       options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>

    <record id="view_stock_move_line_detailed_operation_tree_subserial" model="ir.ui.view">
        <field name="name">stock.move.line.detailed.operations.tree.subserial</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="lot_subserial_id"
                       groups="stock.group_production_lot"
                       column_invisible="parent.show_lots_text"
                       invisible="not lots_visible"
                       optional="show"
                       context="{'default_lot_id': lot_id, 'default_product_id': product_id, 'default_company_id': company_id}"
                       options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_tree_subserial" model="ir.ui.view">
        <field name="name">stock.move.line.tree.subserial</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="lot_subserial_id"
                       groups="stock.group_production_lot"
                       optional="show"
                       context="{'default_lot_id': lot_id, 'default_product_id': product_id, 'default_company_id': company_id}"
                       options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_tree_detailed_subserial" model="ir.ui.view">
        <field name="name">stock.move.line.tree.detailed.subserial</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree_detailed"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="lot_subserial_id"
                       groups="stock.group_production_lot"
                       optional="show"
                       context="{'default_lot_id': lot_id, 'default_product_id': product_id, 'default_company_id': company_id}"
                       options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>

    <record id="view_move_line_form_subserial" model="ir.ui.view">
        <field name="name">stock.move.line.form.subserial</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lot_id']" position="after">
                <field name="lot_subserial_id"
                       groups="stock.group_production_lot"
                       context="{'default_lot_id': lot_id, 'default_product_id': product_id, 'default_company_id': company_id}"
                       options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
