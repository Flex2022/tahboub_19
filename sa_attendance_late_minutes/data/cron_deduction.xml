<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="cron_attendance_late_direct_deduct" model="ir.cron">
        <field name="name">Attendance Late: Direct Deduct From Annual Allocation</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="state">code</field>
        <field name="code">model.cron_deduct_late_from_annual_allocation_direct()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now().replace(hour=22, minute=0, second=0, microsecond=0))"/>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>