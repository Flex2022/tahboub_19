<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_so_wizard_form" model="ir.ui.view">
        <field name="name">import.so.wizard.form</field>
        <field name="model">import.so.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Sale Order">
                <group>
                    <field name="import_type" widget="radio"/>
                    <field name="product_by" widget="radio"/>
                    <field name="is_create_customer"/>
                    <field name="is_confirm_sale"/>
                    <field name="order_no_type" widget="radio"/>
                    <field name="file"/>
                </group>
                <footer>
                    <button name="import_so_apply" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_so_wizard" model="ir.actions.act_window">
        <field name="name">Import Sale Order</field>
        <field name="res_model">import.so.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_import_so_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>

