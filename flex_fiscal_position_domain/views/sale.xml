<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_form_fiscal" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.fiscal.position.domain</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='fiscal_position_id']" position="after">
                <field name="fiscal_position_domain_ids" widget="many2many_tags" context="{'default_company_id': company_id}" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='fiscal_position_id']" position="attributes">
                <attribute name="domain">[('id', 'in', fiscal_position_domain_ids)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>

